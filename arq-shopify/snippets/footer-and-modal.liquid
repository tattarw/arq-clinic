<style>
.arq-footer {
  padding: 56px 0 32px;
  background: var(--surface);
  border-top: 1px solid var(--cream-07);
  margin-top: 0;
}
.arq-footer__top {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid var(--cream-07);
}
@media (min-width: 700px) {
  .arq-footer__top { grid-template-columns: 280px 1fr; }
}
.arq-footer__logo {
  font-family: var(--serif);
  font-size: 21px;
  color: var(--cream);
  margin-bottom: 4px;
}
.arq-footer__logo span { color: var(--gold); }
.arq-footer__tagline {
  font-family: var(--mono);
  font-size: 8px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cream-40);
  margin-bottom: 16px;
}
.arq-footer__about { font-size: 13px; color: var(--cream-40); line-height: 1.7; }

.arq-footer__links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
@media (max-width: 500px) { .arq-footer__links { grid-template-columns: 1fr 1fr; } }

.arq-footer__col-title {
  font-family: var(--mono);
  font-size: 8px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}
.arq-footer__link {
  display: block;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--cream-40);
  padding: 4px 0;
  transition: color 0.2s;
  text-decoration: none;
}
.arq-footer__link:hover { color: var(--cream-70); }

.arq-footer__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}
.arq-footer__legal {
  font-family: var(--mono);
  font-size: 7px;
  letter-spacing: 0.06em;
  color: rgba(242,236,224,0.12);
  line-height: 2;
}
.arq-footer__wa-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cream-40);
  border: 1px solid var(--cream-15);
  padding: 10px 16px;
  border-radius: 2px;
  transition: all 0.2s;
  text-decoration: none;
  white-space: nowrap;
}
.arq-footer__wa-btn:hover { border-color: var(--gold-border); color: var(--gold); }
</style>

{% comment %} snippets/whatsapp-modal.liquid {% endcomment %}
<div class="wa-modal-overlay" id="waModalOverlay" onclick="maybeCloseWAModal(event)">
  <div class="wa-modal" role="dialog" aria-modal="true" aria-label="Start on WhatsApp">
    <div class="wa-modal__handle"></div>
    <h2 class="wa-modal__title">What are you after?</h2>
    <p class="wa-modal__sub">Pick a category. Doctor calls within 2 hours. Delivered in 48.</p>

    <div class="wa-modal__label t-label" style="margin-bottom:12px">I want to —</div>

    <div class="wa-modal__opts" id="waOpts">
      <button class="wa-opt" onclick="selWAOpt(this,'think sharper — modafinil or armodafinil')">
        <span class="wa-opt__icon">🧠</span>
        <span class="wa-opt__name">Think sharper</span>
        <span class="wa-opt__sub">Modafinil · Armodafinil · NAD+</span>
      </button>
      <button class="wa-opt" onclick="selWAOpt(this,'perform better — sildenafil, tadalafil or TRT')">
        <span class="wa-opt__icon">⚡</span>
        <span class="wa-opt__name">Perform better</span>
        <span class="wa-opt__sub">ED · TRT · PT-141</span>
      </button>
      <button class="wa-opt" onclick="selWAOpt(this,'age slower with longevity protocols')">
        <span class="wa-opt__icon">∞</span>
        <span class="wa-opt__name">Age slower</span>
        <span class="wa-opt__sub">Metformin · LDN · Thymosin</span>
      </button>
      <button class="wa-opt" onclick="selWAOpt(this,'explore peptide protocols')">
        <span class="wa-opt__icon">💉</span>
        <span class="wa-opt__name">Peptides</span>
        <span class="wa-opt__sub">BPC-157 · Sermorelin · CJC</span>
      </button>
      <button class="wa-opt" onclick="selWAOpt(this,'look better — hair, skin or weight loss')">
        <span class="wa-opt__icon">✦</span>
        <span class="wa-opt__name">Look better</span>
        <span class="wa-opt__sub">Hair · Skin · Semaglutide</span>
      </button>
      <button class="wa-opt" onclick="selWAOpt(this,'get started')">
        <span class="wa-opt__icon">💬</span>
        <span class="wa-opt__name">Not sure yet</span>
        <span class="wa-opt__sub">We'll guide you</span>
      </button>
    </div>

    <button class="btn btn-primary btn-full" onclick="goToWA()" style="margin-bottom:10px">
      Continue on WhatsApp →
    </button>
    <div style="text-align:center;font-family:var(--mono);font-size:7px;color:var(--cream-40);letter-spacing:0.06em;line-height:2">
      🔒 Completely private · Doctor within 2 hours · Plain packaging
    </div>
  </div>
</div>

<style>
.wa-modal-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.88);
  backdrop-filter: blur(16px);
  z-index: 800;
  align-items: flex-end;
}
.wa-modal-overlay.open { display: flex; }

.wa-modal {
  background: var(--surface);
  width: 100%;
  border-radius: 14px 14px 0 0;
  border: 1px solid var(--cream-07);
  border-bottom: none;
  padding: 8px 20px 40px;
  max-height: 92svh;
  overflow-y: auto;
  animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
}
.wa-modal__handle {
  width: 32px; height: 3px;
  background: var(--cream-15);
  border-radius: 2px;
  margin: 8px auto 20px;
}
.wa-modal__title {
  font-family: var(--serif);
  font-size: 24px;
  font-weight: 400;
  color: var(--cream);
  margin-bottom: 4px;
}
.wa-modal__sub { font-size: 13px; color: var(--cream-40); margin-bottom: 20px; line-height: 1.6; }

.wa-modal__opts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 20px;
}
.wa-opt {
  padding: 16px 12px;
  border: 1px solid var(--cream-07);
  background: var(--ink);
  cursor: pointer;
  text-align: left;
  transition: all 0.18s;
  display: flex;
  flex-direction: column;
  gap: 5px;
  border-radius: 2px;
}
.wa-opt:hover, .wa-opt--selected {
  border-color: var(--gold-border);
  background: var(--gold-lo);
}
.wa-opt__icon { font-size: 18px; }
.wa-opt__name { font-family: var(--serif); font-size: 16px; color: var(--cream); line-height: 1.1; }
.wa-opt__sub { font-family: var(--mono); font-size: 7px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cream-40); }
</style>

<script>
let waSelectedVal = '';

function openWAModal(productName) {
  document.getElementById('waModalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
  if (productName) {
    waSelectedVal = `get ${productName}`;
  }
}
function closeWAModal() {
  document.getElementById('waModalOverlay').classList.remove('open');
  document.body.style.overflow = '';
  waSelectedVal = '';
  document.querySelectorAll('.wa-opt').forEach(b => b.classList.remove('wa-opt--selected'));
}
function maybeCloseWAModal(e) {
  if (e.target.id === 'waModalOverlay') closeWAModal();
}
function selWAOpt(btn, val) {
  document.querySelectorAll('.wa-opt').forEach(b => b.classList.remove('wa-opt--selected'));
  btn.classList.add('wa-opt--selected');
  waSelectedVal = val;
}
function goToWA() {
  const msg = encodeURIComponent('Hi, I want to ' + (waSelectedVal || 'get started with arq'));
  window.open(`https://wa.me/{{ settings.whatsapp_number }}?text=${msg}`, '_blank');
  closeWAModal();
}
document.addEventListener('keydown', e => { if(e.key==='Escape') closeWAModal(); });
</script>
