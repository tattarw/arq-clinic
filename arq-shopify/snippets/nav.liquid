<!-- snippets/nav.liquid -->
<nav class="arq-nav" role="navigation" aria-label="Main navigation">
  <div class="arq-nav__inner">

    <!-- Logo -->
    <a href="/" class="arq-nav__logo" aria-label="arq.clinic home">
      ar<span>q</span><span class="arq-nav__dot">.</span>
    </a>

    <!-- Centre links (desktop) -->
    <div class="arq-nav__links">
      <a href="/collections/all" class="arq-nav__link">Protocols</a>
      <a href="/pages/how-it-works" class="arq-nav__link">How it works</a>
      <a href="/pages/peptides" class="arq-nav__link">Peptides</a>
    </div>

    <!-- Right actions -->
    <div class="arq-nav__actions">
      <!-- Search -->
      <button class="arq-nav__icon-btn" id="searchToggle" aria-label="Search" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>

      <!-- Account -->
      <a href="{% if customer %}/account{% else %}/account/login{% endif %}"
         class="arq-nav__icon-btn"
         aria-label="{% if customer %}My account{% else %}Sign in{% endif %}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        {% if customer %}
          <span class="arq-nav__acct-dot"></span>
        {% endif %}
      </a>

      <!-- Cart -->
      <button class="arq-nav__icon-btn arq-nav__cart-btn" id="cartToggle" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="arq-nav__cart-count {% if cart.item_count == 0 %}hidden{% endif %}" id="cartCount">
          {{ cart.item_count }}
        </span>
      </button>

      <!-- WhatsApp CTA -->
      <button class="arq-nav__wa btn btn-primary btn-sm" onclick="openWAModal()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="arq-nav__wa-label">Start</span>
      </button>
    </div>
  </div>
</nav>

<!-- Search overlay -->
<div class="arq-search" id="searchOverlay" aria-hidden="true">
  <div class="arq-search__inner container">
    <div class="arq-search__bar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="text"
        class="arq-search__input"
        id="searchInput"
        placeholder="What are you looking for?"
        autocomplete="off"
        aria-label="Search protocols"
      >
      <button class="arq-search__close" id="searchClose" aria-label="Close search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="arq-search__suggestions" id="searchSuggestions">
      <div class="arq-search__sug-label t-label">Popular protocols</div>
      <div class="arq-search__pills">
        <button class="arq-search__pill" data-q="modafinil">Modafinil</button>
        <button class="arq-search__pill" data-q="sildenafil">Sildenafil</button>
        <button class="arq-search__pill" data-q="semaglutide">Semaglutide</button>
        <button class="arq-search__pill" data-q="BPC-157">BPC-157</button>
        <button class="arq-search__pill" data-q="finasteride">Finasteride</button>
        <button class="arq-search__pill" data-q="testosterone">Testosterone TRT</button>
        <button class="arq-search__pill" data-q="tretinoin">Tretinoin</button>
        <button class="arq-search__pill" data-q="THC CBD">THC · CBD</button>
      </div>
    </div>
    <div class="arq-search__results" id="searchResults" aria-live="polite"></div>
  </div>
</div>

<style>
/* ── NAV ── */
.arq-nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
}

.arq-nav__logo {
  font-family: var(--serif);
  font-size: 21px;
  font-weight: 400;
  letter-spacing: 0.05em;
  color: var(--cream);
  flex-shrink: 0;
}
.arq-nav__logo span:first-of-type { color: var(--gold); }
.arq-nav__dot { color: var(--gold); }

.arq-nav__links {
  display: none;
  align-items: center;
  gap: 32px;
}
@media (min-width: 900px) { .arq-nav__links { display: flex; } }

.arq-nav__link {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cream-40);
  transition: color 0.2s;
}
.arq-nav__link:hover { color: var(--cream-70); }

.arq-nav__actions {
  display: flex;
  align-items: center;
  gap: 4px;
}

.arq-nav__icon-btn {
  background: none;
  border: none;
  color: var(--cream-40);
  padding: 10px;
  border-radius: var(--radius);
  transition: color 0.2s;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.arq-nav__icon-btn:hover { color: var(--cream-70); }

.arq-nav__acct-dot {
  position: absolute;
  top: 8px; right: 8px;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--gold);
}

.arq-nav__cart-count {
  position: absolute;
  top: 5px; right: 5px;
  min-width: 16px; height: 16px;
  background: var(--gold);
  color: var(--bg);
  font-family: var(--mono);
  font-size: 8px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

.arq-nav__wa { margin-left: 8px; }
.arq-nav__wa-label { display: none; }
@media (min-width: 480px) { .arq-nav__wa-label { display: inline; } }

/* ── SEARCH OVERLAY ── */
.arq-search {
  position: fixed;
  top: var(--nav-h); left: 0; right: 0;
  z-index: 400;
  background: rgba(12,11,9,0.97);
  backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--cream-07);
  transform: translateY(-100%);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.25s;
  pointer-events: none;
  max-height: calc(100vh - var(--nav-h));
  overflow-y: auto;
}
.arq-search.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: all;
}

.arq-search__inner { padding: 24px 20px; max-width: 640px; margin: 0 auto; }

.arq-search__bar {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface);
  border: 1px solid var(--cream-15);
  border-radius: var(--radius);
  padding: 0 16px;
  margin-bottom: 24px;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.arq-search__bar:focus-within {
  border-color: var(--gold-border);
  box-shadow: 0 0 0 3px var(--gold-lo);
}

.arq-search__input {
  flex: 1;
  font-family: var(--serif);
  font-size: 20px;
  font-style: italic;
  padding: 18px 0;
  color: var(--cream);
}
.arq-search__input::placeholder { color: var(--cream-40); }

.arq-search__close {
  background: none;
  border: none;
  color: var(--cream-40);
  padding: 4px;
  transition: color 0.2s;
}
.arq-search__close:hover { color: var(--cream); }

.arq-search__sug-label { margin-bottom: 12px; }

.arq-search__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 20px;
}

.arq-search__pill {
  background: none;
  border: 1px solid var(--cream-15);
  color: var(--cream-70);
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 7px 14px;
  border-radius: 20px;
  transition: all 0.18s;
}
.arq-search__pill:hover {
  border-color: var(--gold-border);
  color: var(--gold);
  background: var(--gold-lo);
}

/* Search results */
.arq-search__results { display: flex; flex-direction: column; gap: 1px; background: var(--cream-07); border-radius: var(--radius); overflow: hidden; }

.arq-search__result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  background: var(--surface);
  padding: 16px 18px;
  text-decoration: none;
  transition: background 0.15s;
  border-left: 2px solid transparent;
}
.arq-search__result:hover {
  background: var(--card);
  border-left-color: var(--gold);
}

.arq-search__result-name {
  font-family: var(--serif);
  font-size: 17px;
  color: var(--cream);
  margin-bottom: 2px;
}
.arq-search__result-meta {
  font-family: var(--mono);
  font-size: 8px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cream-40);
}
.arq-search__result-price {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--cream);
  text-align: right;
  flex-shrink: 0;
}
.arq-search__result-unit {
  font-family: var(--mono);
  font-size: 7px;
  color: var(--cream-40);
  letter-spacing: 0.08em;
}

/* Toast */
.arq-toast {
  position: fixed;
  bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--surface);
  border: 1px solid var(--cream-15);
  color: var(--cream);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  padding: 12px 24px;
  border-radius: 2px;
  z-index: 9000;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s;
  white-space: nowrap;
}
.arq-toast--visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
  pointer-events: all;
}
.arq-toast--success { border-color: var(--green-border); }
.arq-toast--error   { border-color: var(--red-border); }

/* Announcement */
.announcement-bar {
  background: var(--surface);
  border-bottom: 1px solid var(--cream-07);
  padding: 8px 0;
  text-align: center;
}
</style>

<script>
// ── SEARCH ──
const searchToggle  = document.getElementById('searchToggle');
const searchClose   = document.getElementById('searchClose');
const searchOverlay = document.getElementById('searchOverlay');
const searchInput   = document.getElementById('searchInput');
const searchResults = document.getElementById('searchResults');
const searchSugs    = document.getElementById('searchSuggestions');

function openSearch() {
  searchOverlay.classList.add('open');
  searchOverlay.setAttribute('aria-hidden','false');
  searchToggle.setAttribute('aria-expanded','true');
  setTimeout(() => searchInput.focus(), 100);
}
function closeSearch() {
  searchOverlay.classList.remove('open');
  searchOverlay.setAttribute('aria-hidden','true');
  searchToggle.setAttribute('aria-expanded','false');
  searchInput.value = '';
  searchResults.innerHTML = '';
  searchSugs.style.display = 'block';
}

searchToggle.addEventListener('click', openSearch);
searchClose.addEventListener('click', closeSearch);
document.addEventListener('keydown', e => { if(e.key === 'Escape') closeSearch(); });

// Pill clicks
document.querySelectorAll('.arq-search__pill').forEach(p => {
  p.addEventListener('click', () => {
    searchInput.value = p.dataset.q;
    doSearch(p.dataset.q);
  });
});

// Live search
searchInput.addEventListener('input', e => doSearch(e.target.value.trim()));

function doSearch(q) {
  if (!q) {
    searchResults.innerHTML = '';
    searchSugs.style.display = 'block';
    return;
  }
  searchSugs.style.display = 'none';

  fetch(`/search/suggest.json?q=${encodeURIComponent(q)}&resources[type]=product&resources[limit]=8`)
    .then(r => r.json())
    .then(data => {
      const products = data.resources?.results?.products || [];
      if (!products.length) {
        searchResults.innerHTML = `
          <div style="padding:24px;text-align:center">
            <div style="font-family:var(--serif);font-size:18px;font-style:italic;color:var(--cream-40);margin-bottom:6px">No results for "${q}"</div>
            <div style="font-size:12px;color:var(--cream-40)">Try a molecule name — modafinil, sildenafil, semaglutide…</div>
          </div>`;
        return;
      }
      searchResults.innerHTML = products.map(p => `
        <a href="${p.url}" class="arq-search__result" onclick="closeSearch()">
          <div>
            <div class="arq-search__result-name">${p.title}</div>
            <div class="arq-search__result-meta">${p.product_type || 'Protocol'}</div>
          </div>
          <div class="arq-search__result-price">
            <div>${p.price}</div>
            <div class="arq-search__result-unit">/month</div>
          </div>
        </a>
      `).join('');
    })
    .catch(() => {
      searchResults.innerHTML = `<div style="padding:16px;color:var(--cream-40);font-size:13px;text-align:center">Search unavailable. <a href="/search?q=${encodeURIComponent(q)}" style="color:var(--gold)">Try full search →</a></div>`;
    });
}

// ── CART COUNT ──
function updateCartCount(count) {
  const el = document.getElementById('cartCount');
  if (!el) return;
  el.textContent = count;
  el.classList.toggle('hidden', count === 0);
}
</script>
