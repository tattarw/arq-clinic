<style>
/* ── HERO ── */
.hero {
  min-height: calc(100svh - var(--nav-h));
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48px 20px 60px;
  position: relative;
  overflow: hidden;
  text-align: center;
}

.hero__pills { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.hero__pill {
  position: absolute;
  opacity: 0;
  animation: floatIn 1s ease forwards;
}
@keyframes floatIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero__vial { position: absolute; opacity: 0; animation: floatIn 1s ease forwards; }
.hero__vial-cap { width: 7px; height: 10px; background: rgba(200,151,58,0.4); border-radius: 2px 2px 0 0; margin: 0 auto; }
.hero__vial-body { width: 7px; height: 44px; background: linear-gradient(180deg,rgba(242,236,224,0.18) 0%,rgba(242,236,224,0.04) 100%); border-radius: 0 0 3px 3px; margin: 0 auto; }

.hero__inner { position: relative; z-index: 1; width: 100%; max-width: 580px; }

.hero__eyebrow {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}
.hero__headline {
  font-family: var(--serif);
  font-size: clamp(40px, 11vw, 80px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 10px;
}
.hero__headline em { font-style: italic; color: var(--gold); }
.hero__sub { font-size: 14px; color: var(--cream-40); margin-bottom: 24px; }

/* Search */
.hero__search-wrap { position: relative; margin-bottom: 20px; }
.hero__search-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface);
  border: 1px solid var(--cream-15);
  border-radius: var(--radius-lg);
  padding: 0 16px;
  transition: border-color 0.25s, box-shadow 0.25s;
  position: relative;
}
.hero__search-bar.focused,
.hero__search-bar:focus-within {
  border-color: var(--gold-border);
  box-shadow: 0 0 0 3px var(--gold-lo), 0 8px 40px rgba(0,0,0,0.4);
}
.hero__search-icon { color: var(--cream-40); flex-shrink: 0; transition: color 0.2s; }
.hero__search-bar.focused .hero__search-icon { color: var(--gold); }
.hero__search-input {
  flex: 1;
  font-family: var(--serif);
  font-size: clamp(18px, 4vw, 24px);
  font-style: italic;
  padding: 22px 0;
  color: var(--cream);
}
.hero__search-input::placeholder { color: var(--cream-40); }
.hero__search-clear {
  background: none; border: none;
  color: var(--cream-40); font-size: 20px;
  display: none; transition: color 0.2s; padding: 4px;
}
.hero__search-clear:hover { color: var(--cream); }
.hero__search-input:not(:placeholder-shown) ~ .hero__search-clear { display: block; }

/* Search results */
.hero__search-results {
  position: absolute;
  top: calc(100% + 4px);
  left: 0; right: 0;
  background: var(--surface);
  border: 1px solid var(--cream-15);
  border-radius: var(--radius-lg);
  overflow: hidden;
  z-index: 200;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.hero__search-results:empty { display: none; }

.hero__result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 18px;
  text-decoration: none;
  transition: background 0.15s;
  border-bottom: 1px solid var(--cream-07);
  border-left: 2px solid transparent;
}
.hero__result:last-child { border-bottom: none; }
.hero__result:hover {
  background: var(--card);
  border-left-color: var(--gold);
}
.hero__result-name { font-family: var(--serif); font-size: 16px; color: var(--cream); margin-bottom: 2px; line-height: 1.2; }
.hero__result-cat { font-family: var(--mono); font-size: 8px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cream-40); }
.hero__result-price { font-family: var(--serif); font-size: 15px; color: var(--cream); flex-shrink: 0; text-align: right; }
.hero__result-unit { font-family: var(--mono); font-size: 7px; color: var(--cream-40); letter-spacing: 0.06em; }

/* Suggestions */
.hero__suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  justify-content: center;
  margin-bottom: 32px;
}
.sug {
  background: none;
  border: 1px solid var(--cream-15);
  color: var(--cream-70);
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 7px 14px;
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.18s;
  text-decoration: none;
  display: inline-flex;
}
.sug:hover { border-color: var(--gold-border); color: var(--gold); background: var(--gold-lo); }
.sug--ghost { color: var(--cream-40); }

/* Stats */
.hero__stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}
.hero__stat { display: flex; flex-direction: column; align-items: center; gap: 2px; padding: 0 16px; }
.hero__stat-n { font-family: var(--serif); font-size: 22px; color: var(--cream); line-height: 1; }
.hero__stat-l { font-family: var(--mono); font-size: 7px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream-40); }
.hero__stat-sep { width: 1px; height: 28px; background: var(--cream-15); flex-shrink: 0; }

/* Ticker */
.ticker { overflow: hidden; border-top: 1px solid var(--cream-07); border-bottom: 1px solid var(--cream-07); background: var(--surface); padding: 11px 0; }
.ticker__track { overflow: hidden; }
.ticker__inner { display: flex; align-items: center; white-space: nowrap; animation: ticker 32s linear infinite; gap: 16px; }
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.ticker__item { font-family: var(--mono); font-size: 8px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(242,236,224,0.2); flex-shrink: 0; }
.ticker__dot { width: 3px; height: 3px; border-radius: 50%; background: var(--gold); opacity: 0.5; flex-shrink: 0; }

/* Manifesto */
.manifesto { padding: 72px 0; background: var(--surface); border-bottom: 1px solid var(--cream-07); }
.manifesto__body { margin-top: 24px; }
.manifesto__p { font-family: var(--serif); font-size: clamp(17px, 3.5vw, 22px); font-weight: 400; line-height: 1.7; color: var(--cream-70); margin-bottom: 20px; }
.manifesto__p em { font-style: italic; color: var(--cream); }
.manifesto__p strong { color: var(--gold); font-weight: 400; }

/* Protocols grid */
.featured-protocols { padding: 72px 0; }
.featured-protocols__header { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
.protocols-grid { display: grid; grid-template-columns: 1fr; gap: 1px; background: var(--cream-07); }
@media (min-width: 480px) { .protocols-grid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 860px) { .protocols-grid { grid-template-columns: 1fr 1fr 1fr; } }

/* How it works */
.how-section { padding: 72px 0; background: var(--surface); border-top: 1px solid var(--cream-07); border-bottom: 1px solid var(--cream-07); }
.how-steps { display: flex; flex-direction: column; gap: 1px; background: var(--cream-07); border-radius: var(--radius); overflow: hidden; }
.how-step {
  display: grid;
  grid-template-columns: 44px 1fr;
  gap: 16px;
  background: var(--ink);
  padding: 24px 20px;
  border-bottom: 1px solid var(--cream-07);
}
.how-step--last { border-bottom: none; }
.how-step__n { font-family: var(--serif); font-size: 36px; color: rgba(200,151,58,0.15); line-height: 1; margin-top: -4px; }
.how-step__title { font-family: var(--serif); font-size: 18px; color: var(--cream); margin-bottom: 5px; }
.how-step__body { font-size: 13px; color: var(--cream-40); line-height: 1.7; }
.how-step__time { font-family: var(--mono); font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-top: 8px; display: flex; align-items: center; gap: 8px; }
.how-step__time::before { content: ''; width: 12px; height: 1px; background: var(--gold); display: block; }

/* Trust strip */
.trust-strip { padding: 16px 0; background: var(--surface); border-bottom: 1px solid var(--cream-07); }
.trust-items { display: flex; align-items: center; justify-content: center; gap: 0; flex-wrap: wrap; }
.trust-item { display: flex; align-items: center; gap: 8px; padding: 8px 16px; font-family: var(--mono); font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream-40); }
.trust-sep { width: 1px; height: 20px; background: var(--cream-07); flex-shrink: 0; }
@media (max-width: 600px) { .trust-sep { display: none; } .trust-items { flex-direction: column; } }

/* Bottom CTA */
.bottom-cta { padding: 80px 0; position: relative; overflow: hidden; }
.bottom-cta__glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(200,151,58,0.05) 0%, transparent 60%); pointer-events: none; }
.bottom-cta__wm { position: absolute; font-family: var(--serif); font-size: clamp(80px,25vw,180px); color: rgba(200,151,58,0.025); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; font-style: italic; white-space: nowrap; }

.section-full { padding-left: 0; padding-right: 0; }
</style>

<script>
// ── HERO SEARCH ──
const heroInput   = document.getElementById('heroSearchInput');
const heroResults = document.getElementById('heroSearchResults');
const heroSugs    = document.getElementById('heroSuggestions');
const heroClear   = document.getElementById('heroSearchClear');

heroInput?.addEventListener('input', e => {
  const q = e.target.value.trim();
  if (!q) {
    heroResults.innerHTML = '';
    heroSugs.style.display = 'flex';
    return;
  }
  heroSugs.style.display = 'none';
  doHeroSearch(q);
});

function doHeroSearch(q) {
  fetch(`/search/suggest.json?q=${encodeURIComponent(q)}&resources[type]=product&resources[limit]=6`)
    .then(r => r.json())
    .then(data => {
      const products = data.resources?.results?.products || [];
      if (!products.length) {
        heroResults.innerHTML = `
          <div style="padding:20px;text-align:center">
            <div style="font-family:var(--serif);font-size:17px;font-style:italic;color:var(--cream-40);margin-bottom:4px">No results for "${q}"</div>
            <div style="font-size:12px;color:var(--cream-40)">Try: modafinil, sildenafil, BPC-157…</div>
          </div>`;
        return;
      }
      heroResults.innerHTML = products.map(p => `
        <a href="${p.url}" class="hero__result">
          <div>
            <div class="hero__result-name">${p.title}</div>
            <div class="hero__result-cat">${p.product_type || 'Protocol'}</div>
          </div>
          <div>
            <div class="hero__result-price">${p.price}</div>
            <div class="hero__result-unit">/month</div>
          </div>
        </a>
      `).join('');
    })
    .catch(() => {
      heroResults.innerHTML = `<div style="padding:16px;text-align:center;font-size:12px;color:var(--cream-40)">
        <a href="/search?q=${encodeURIComponent(q)}" style="color:var(--gold)">View all results for "${q}" →</a>
      </div>`;
    });
}

function heroSearchFor(q) {
  heroInput.value = q;
  heroInput.focus();
  doHeroSearch(q);
}

function clearHeroSearch() {
  heroInput.value = '';
  heroResults.innerHTML = '';
  heroSugs.style.display = 'flex';
  heroInput.focus();
}

// Close results on outside click
document.addEventListener('click', e => {
  if (!e.target.closest('.hero__search-wrap')) {
    heroResults.innerHTML = '';
    if (!heroInput.value) heroSugs.style.display = 'flex';
  }
});
</script>
