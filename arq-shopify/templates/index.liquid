{% comment %} templates/index.liquid {% endcomment %}

<!-- ─── HERO ─── -->
<section class="hero">
  <div class="hero__pills" aria-hidden="true">
    <div class="hero__pill" style="width:22px;height:13px;background:#d4a574;border-radius:20px;top:16%;left:10%;transform:rotate(-18deg);animation-delay:0.3s"></div>
    <div class="hero__pill" style="width:15px;height:15px;background:#b8c4aa;border-radius:50%;top:20%;right:15%;animation-delay:0.5s"></div>
    <div class="hero__pill" style="width:30px;height:10px;background:#c8a8d4;border-radius:20px;top:72%;left:7%;transform:rotate(22deg);animation-delay:0.4s"></div>
    <div class="hero__pill" style="width:18px;height:18px;background:#a8c4b8;border-radius:50%;top:74%;right:10%;animation-delay:0.6s"></div>
    <div class="hero__pill" style="width:34px;height:11px;background:#d4c4a8;border-radius:20px;top:42%;left:4%;transform:rotate(-6deg);animation-delay:0.7s"></div>
    <div class="hero__pill" style="width:13px;height:13px;background:#c4a8a8;border-radius:50%;top:32%;right:6%;animation-delay:0.35s"></div>
    <!-- Vial -->
    <div class="hero__vial" style="top:26%;right:22%;animation-delay:0.5s">
      <div class="hero__vial-cap"></div>
      <div class="hero__vial-body"></div>
    </div>
  </div>

  <div class="hero__inner">
    <div class="hero__eyebrow animate-up">India's first biohacker clinic</div>

    <h1 class="hero__headline animate-up animate-up-1">
      Your body.<br><em>Your call.</em>
    </h1>

    <p class="hero__sub animate-up animate-up-2">
      What are you looking for?
    </p>

    <!-- ── SEARCH BAR ── -->
    <div class="hero__search-wrap animate-up animate-up-2">
      <div class="hero__search-bar" id="heroSearchBar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hero__search-icon">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          class="hero__search-input"
          id="heroSearchInput"
          placeholder="modafinil, sildenafil, BPC-157…"
          autocomplete="off"
          aria-label="Search protocols"
          onfocus="this.closest('.hero__search-bar').classList.add('focused')"
          onblur="this.closest('.hero__search-bar').classList.remove('focused')"
        >
        <button class="hero__search-clear" id="heroSearchClear" onclick="clearHeroSearch()" aria-label="Clear search">×</button>
      </div>

      <!-- Results dropdown -->
      <div class="hero__search-results" id="heroSearchResults" role="listbox" aria-label="Search results"></div>
    </div>

    <!-- Suggestion pills -->
    <div class="hero__suggestions animate-up animate-up-3" id="heroSuggestions">
      <button class="sug" onclick="heroSearchFor('modafinil')">Modafinil</button>
      <button class="sug" onclick="heroSearchFor('armodafinil')">Armodafinil</button>
      <button class="sug" onclick="heroSearchFor('sildenafil')">Sildenafil</button>
      <button class="sug" onclick="heroSearchFor('semaglutide')">Semaglutide</button>
      <button class="sug" onclick="heroSearchFor('BPC-157')">BPC-157</button>
      <button class="sug" onclick="heroSearchFor('finasteride')">Finasteride</button>
      <button class="sug" onclick="heroSearchFor('THC CBD')">THC · CBD</button>
      <a href="/collections/all" class="sug sug--ghost">Browse all →</a>
    </div>

    <!-- Stats -->
    <div class="hero__stats animate-up animate-up-4">
      <div class="hero__stat">
        <div class="hero__stat-n">26+</div>
        <div class="hero__stat-l">Protocols</div>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <div class="hero__stat-n">2hr</div>
        <div class="hero__stat-l">Doctor call</div>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <div class="hero__stat-n">48hr</div>
        <div class="hero__stat-l">Delivery</div>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <div class="hero__stat-n">₹0</div>
        <div class="hero__stat-l">Consult fee</div>
      </div>
    </div>
  </div>
</section>

<!-- ─── TICKER ─── -->
<div class="ticker" aria-hidden="true">
  <div class="ticker__track">
    <div class="ticker__inner">
      {% assign ticker_items = "Modafinil,Armodafinil,Sildenafil,Tadalafil,Semaglutide,BPC-157,Sermorelin,THC·CBD,NAD+,Finasteride,Tretinoin,TRT,100% Legal,WhatsApp Native,48hr Delivery,Doctor Included,Discreet Packaging" | split: "," %}
      {% for item in ticker_items %}
        <span class="ticker__item">{{ item }}</span><span class="ticker__dot"></span>
      {% endfor %}
      {% for item in ticker_items %}
        <span class="ticker__item">{{ item }}</span><span class="ticker__dot"></span>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ─── MANIFESTO ─── -->
<section class="manifesto section-full">
  <div class="container-text">
    <div class="eyebrow">Why arq exists</div>
    <div class="manifesto__body">
      <p class="manifesto__p">You've done the research. You know the difference between modafinil and armodafinil. You've been sourcing things from <em>somewhere</em> — and you know it's not ideal.</p>
      <p class="manifesto__p">India's entire medical system assumes the doctor knows best. The patient arrives with symptoms. The doctor decides the solution. The pharmacist enforces the gate.</p>
      <p class="manifesto__p">But you're not a patient. <strong>You're informed.</strong> You know what you want. You just need someone to handle the paperwork.</p>
      <p class="manifesto__p">That's arq. Every protocol, every peptide, every prescription — legally prescribed, doctor supervised, delivered discreetly. <strong>No waiting rooms. No explaining yourself.</strong></p>
    </div>
  </div>
</section>

<!-- ─── FEATURED PROTOCOLS ─── -->
<section class="featured-protocols section-full">
  <div class="container">
    <div class="featured-protocols__header">
      <div class="eyebrow">Protocols</div>
      <h2 class="t-headline">What people <em>actually</em> want.</h2>
      <a href="/collections/all" class="btn btn-secondary btn-sm">Browse all 26 →</a>
    </div>

    <div class="protocols-grid">
      {% assign featured_handles = settings.featured_products | split: ',' %}
      {% for handle in featured_handles limit: 9 %}
        {% assign p = all_products[handle | strip] %}
        {% if p != blank %}
          {% render 'product-card', product: p %}
        {% endif %}
      {% endfor %}

      <!-- Fallback: render from collection if no featured set -->
      {% if featured_handles.size == 0 %}
        {% assign collection = collections['all'] %}
        {% for p in collection.products limit: 9 %}
          {% render 'product-card', product: p %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<!-- ─── HOW IT WORKS ─── -->
<section class="how-section section-full">
  <div class="container" style="max-width:640px">
    <div class="eyebrow">The process</div>
    <h2 class="t-headline" style="margin-bottom:32px">
      From decision to door.<br><em>Seamlessly.</em>
    </h2>

    <div class="how-steps">
      <div class="how-step">
        <div class="how-step__n">1</div>
        <div class="how-step__content">
          <div class="how-step__title">You decide</div>
          <div class="how-step__body">Search for what you want. Read what it does, what it costs, what happens next. Buy. No forms, no intake questionnaire. 60 seconds.</div>
          <div class="how-step__time">60 seconds</div>
        </div>
      </div>
      <div class="how-step">
        <div class="how-step__n">2</div>
        <div class="how-step__content">
          <div class="how-step__title">Doctor calls you</div>
          <div class="how-step__body">A licensed physician — not a chatbot — calls within 2 hours. 5 minutes. They issue your e-prescription. No lecture, no judgment.</div>
          <div class="how-step__time">Within 2 hours</div>
        </div>
      </div>
      <div class="how-step">
        <div class="how-step__n">3</div>
        <div class="how-step__content">
          <div class="how-step__title">It arrives. Discreetly.</div>
          <div class="how-step__body">Plain matte box. No brand name outside. No product name. Looks like any other courier. Inside: your protocol card.</div>
          <div class="how-step__time">48 hours</div>
        </div>
      </div>
      <div class="how-step how-step--last">
        <div class="how-step__n">4</div>
        <div class="how-step__content">
          <div class="how-step__title">One tap to refill</div>
          <div class="how-step__body">Day 25 we message you on WhatsApp. Same order? Reply YES. Ships today. Your doctor knows your case. No re-intake. Ever.</div>
          <div class="how-step__time">Every month</div>
        </div>
      </div>
    </div>
  </div>
</section>

