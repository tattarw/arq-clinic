# ============================================================================
# arq.clinic Backend Configuration Template
# Copy this file to .env and fill in actual values
# Never commit .env file with real secrets to version control
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://arq_app_service:password@localhost:5432/arq_clinic
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arq_clinic
DB_USER=arq_app_service
DB_PASSWORD=change_this_strong_password
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_TIMEOUT=30000

# ============================================================================
# RAZORPAY PAYMENT GATEWAY
# ============================================================================
# Test Keys (development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Production Keys (uncomment for production)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Razorpay Settings
RAZORPAY_API_URL=https://api.razorpay.com/v1
RAZORPAY_WEBHOOK_URL=https://api.arq.clinic/webhooks/razorpay
RAZORPAY_AUTO_CAPTURE=true
RAZORPAY_AUTO_CAPTURE_AMOUNT=0

# ============================================================================
# WHATSAPP BUSINESS API
# ============================================================================
# Meta/Facebook Cloud API
WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_long_lived_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_WEBHOOK_URL=https://api.arq.clinic/webhooks/whatsapp
WHATSAPP_MESSAGE_TEMPLATE_NAMESPACE=your_namespace

# WhatsApp Settings
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_MS=5000
WHATSAPP_RATE_LIMIT_PER_SECOND=80

# ============================================================================
# N8N AUTOMATION ENGINE
# ============================================================================
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# N8N Workflows
N8N_NEW_ORDER_WORKFLOW_ID=workflow_id_1
N8N_CALLBACK_WORKFLOW_ID=workflow_id_2
N8N_FULFILLMENT_WORKFLOW_ID=workflow_id_3
N8N_REFILL_WORKFLOW_ID=workflow_id_4
N8N_WINBACK_WORKFLOW_ID=workflow_id_5

# ============================================================================
# SHOPIFY INTEGRATION
# ============================================================================
SHOPIFY_STORE_NAME=your_store_name.myshopify.com
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_PASSWORD=your_api_password
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# PRESCRIPTION SERVICE
# ============================================================================
PRESCRIPTION_SERVICE_URL=https://prescription.arq.clinic/api
PRESCRIPTION_SERVICE_TOKEN=your_prescription_service_token
PRESCRIPTION_TEMPLATE_URL=https://templates.arq.clinic/prescription
PRESCRIPTION_VALIDITY_DAYS=365
PRESCRIPTION_REFILL_INTERVAL=30

# ============================================================================
# FULFILLMENT & LOGISTICS
# ============================================================================
FULFILLMENT_API_URL=https://fulfillment.arq.clinic/api
FULFILLMENT_API_TOKEN=your_fulfillment_api_token
FULFILLMENT_WAREHOUSE_ID=warehouse_001
FULFILLMENT_DEFAULT_CARRIER=shiprocket

# Shipping Providers (configure for each carrier)
SHIPROCKET_API_URL=https://apiv2.shiprocket.in
SHIPROCKET_API_KEY=your_shiprocket_api_key
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password

# ============================================================================
# DOCTOR ASSIGNMENT ENGINE
# ============================================================================
DOCTOR_SLA_DURATION_HOURS=2
DOCTOR_ESCALATION_THRESHOLD_PERCENT=75
DOCTOR_MIN_QUALITY_SCORE=3.5
DOCTOR_CHECK_SLA_INTERVAL_MINUTES=15
DOCTOR_MAX_RETRIES=3
DOCTOR_RETRY_BACKOFF_MS=5000

# ============================================================================
# PAYMENT RETRY CONFIGURATION
# ============================================================================
PAYMENT_AUTO_RETRY_ENABLED=true
PAYMENT_RETRY_DELAYS=[3600000,21600000,86400000,259200000]
PAYMENT_MAX_RETRY_ATTEMPTS=4
PAYMENT_NOTIFICATION_ON_RETRY=true

# ============================================================================
# SUBSCRIPTION MANAGEMENT
# ============================================================================
SUBSCRIPTION_DEFAULT_DURATION_MONTHS=12
SUBSCRIPTION_AUTO_REFILL_ENABLED=true
SUBSCRIPTION_REFILL_REMINDER_DAYS=5
SUBSCRIPTION_REFILL_VERIFICATION_INTERVAL=3
SUBSCRIPTION_PAUSE_LIMIT_DAYS=90
SUBSCRIPTION_AUTO_CANCEL_AFTER_FAILED_DAYS=30

# ============================================================================
# WIN-BACK CAMPAIGN SETTINGS
# ============================================================================
WINBACK_STAGE_1_DELAY_DAYS=7
WINBACK_STAGE_2_DELAY_DAYS=7
WINBACK_STAGE_3_DELAY_DAYS=16
WINBACK_STAGE_2_DISCOUNT_PERCENT=20
WINBACK_STAGE_3_DISCOUNT_PERCENT=30
WINBACK_STAGE_3_FREE_SHIPPING=true

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================
NOTIFICATION_EMAIL_FROM=notifications@arq.clinic
NOTIFICATION_SMS_FROM=ARQ
NOTIFICATION_WHATSAPP_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_TIMEOUT_MS=30000

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE_MB=100
LOG_RETENTION_DAYS=30

# Sentry Error Tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=localhost
API_PORT=3000
API_PROTOCOL=http
API_BASE_URL=http://localhost:3000/api

# CORS Settings
CORS_ORIGIN=http://localhost:3000,https://arq.clinic
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_MAX_AGE=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_PATHS=[/health,/metrics]

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_long
ENCRYPTION_ALGORITHM=aes-256-cbc

# HTTPS & SSL (for production)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development
APP_VERSION=1.0.0
APP_NAME=arq-clinic-backend

# Feature Flags
FEATURE_DOCTOR_ASSIGNMENT_ENABLED=true
FEATURE_AUTO_RETRY_ENABLED=true
FEATURE_WINBACK_ENABLED=true
FEATURE_REFERRAL_ENABLED=true
FEATURE_DOCTOR_QUALITY_SCORING=true

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# Database Maintenance
DB_CLEANUP_ENABLED=true
DB_CLEANUP_FREQUENCY=weekly
DB_VACUUM_ENABLED=true

# ============================================================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ============================================================================

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXX-X

# Mixpanel (Optional)
MIXPANEL_TOKEN=

# SendGrid Email Service (Optional)
SENDGRID_API_KEY=

# Twilio SMS Service (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 (for document storage, optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=arq-clinic

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# Only for local development - remove in production
DEBUG=false
MOCK_PAYMENTS=false
MOCK_WHATSAPP=false
TEST_MODE=false
SEED_DATABASE=false

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with real values
# 2. Use strong, unique passwords in production
# 3. Rotate secrets regularly
# 4. Use environment-specific configurations
# 5. Store sensitive values in a secret management system
# 6. Enable HTTPS in production
# 7. Use database replicas for high availability
# 8. Implement proper logging and monitoring
# 9. Set up automated backups
# 10. Keep dependencies updated
