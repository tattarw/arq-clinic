<script>
// ─── Nav scroll transition ───
const nav = document.querySelector('.nav');
const setNav = () => nav.classList.toggle('scrolled', window.scrollY > 100);
setNav();
window.addEventListener('scroll', setNav, {passive:true});

// ─── Scroll reveal ───
const reveal = document.querySelectorAll('.reveal');
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if(e.isIntersecting){
      e.target.classList.add('in');
      io.unobserve(e.target);
    }
  });
}, {threshold:0.12, rootMargin:'0px 0px -40px 0px'});

reveal.forEach(el => io.observe(el));

// ─── Smooth scroll for anchor links ───
document.querySelectorAll('a[href^="#"]').forEach(link => {
  link.addEventListener('click', (e) => {
    const target = document.querySelector(link.getAttribute('href'));
    if(target) {
      e.preventDefault();
      target.scrollIntoView({behavior:'smooth'});
    }
  });
});

// ─── FAQ accordion ───
document.querySelectorAll('.faq-item details').forEach(detail => {
  detail.addEventListener('toggle', () => {
    if(detail.open) {
      detail.scrollIntoView({behavior:'smooth', block:'nearest'});
    }
  });
});

// ─── Dropdown menu ───
const dropdownOverlay = document.getElementById('dropdownOverlay');
const dropdownPanel = document.getElementById('dropdownPanel');
const dropdownClose = document.getElementById('dropdownClose');
const hamburger = document.querySelector('.nav-hamburger');

function openDropdown() {
  dropdownOverlay.classList.add('open');
  dropdownPanel.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeDropdown() {
  dropdownOverlay.classList.remove('open');
  dropdownPanel.classList.remove('open');
  document.body.style.overflow = '';
}

if (hamburger) hamburger.addEventListener('click', openDropdown);
if (dropdownClose) dropdownClose.addEventListener('click', closeDropdown);
if (dropdownOverlay) dropdownOverlay.addEventListener('click', closeDropdown);

// Highlight current page in dropdown
const currentPath = window.location.pathname.replace(/\.html$/, '').replace(/\/$/, '');
document.querySelectorAll('.dropdown-link').forEach(link => {
  const href = link.getAttribute('href').replace(/\.html$/, '').replace(/\/$/, '');
  if (currentPath === href || currentPath.endsWith(href)) {
    link.classList.add('active');
  }
});

// ─── Waitlist modal ───
function openWaitlist() {
  const ol = document.getElementById('waitlistOverlay');
  if (ol) { ol.classList.add('open'); document.body.style.overflow = 'hidden'; }
}
function closeWaitlist() {
  const ol = document.getElementById('waitlistOverlay');
  if (ol) { ol.classList.remove('open'); document.body.style.overflow = ''; }
}

// Close on overlay click
const wlOverlay = document.getElementById('waitlistOverlay');
if (wlOverlay) wlOverlay.addEventListener('click', function(e) {
  if (e.target === wlOverlay) closeWaitlist();
});

function submitWaitlist(e) {
  e.preventDefault();
  const btn = document.getElementById('wlSubmit');
  const name = document.getElementById('wlName').value;
  const email = document.getElementById('wlEmail').value;
  const phone = document.getElementById('wlPhone').value;
  btn.disabled = true;
  btn.textContent = 'Joining...';

  const data = { name, email, phone, page: window.location.pathname, ts: new Date().toISOString() };

  fetch('https://arq.clinic/api/waitlist', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).catch(() => {
    const existing = JSON.parse(localStorage.getItem('arq_waitlist') || '[]');
    existing.push(data);
    localStorage.setItem('arq_waitlist', JSON.stringify(existing));
  }).finally(() => {
    document.getElementById('waitlistForm').style.display = 'none';
    document.getElementById('waitlistSuccess').style.display = 'block';
    setTimeout(closeWaitlist, 3000);
  });
}

document.querySelectorAll('a[href="#cta"], a[href="#"], .nav-link').forEach(link => {
  const text = link.textContent.toLowerCase();
  if (text.includes('waitlist') || text.includes('talk to')) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      closeDropdown();
      openWaitlist();
    });
  }
});

// ─── Read more fold ───
const readMoreBtn = document.getElementById('readMoreBtn');
const articleFold = document.getElementById('articleFold');
const readMoreWrap = document.querySelector('.read-more-wrap');
if (readMoreBtn && articleFold) {
  readMoreBtn.addEventListener('click', function() {
    articleFold.classList.add('expanded');
    if (readMoreWrap) readMoreWrap.classList.add('hidden');
  });
}

</script>

<!-- ─── WAITLIST MODAL ─── -->
<div class="waitlist-overlay" id="waitlistOverlay">
  <div class="waitlist-modal">
    <button class="waitlist-modal-close" onclick="closeWaitlist()" aria-label="Close"><i class="ph-bold ph-x"></i></button>
    <div id="waitlistForm">
      <h2>Join the <em>waitlist</em></h2>
      <p class="wl-sub">100+ biomarkers. A dedicated physician. Protocol delivered to your door. Be first in line when we launch.</p>
      <form class="waitlist-form" onsubmit="submitWaitlist(event)">
        <input type="text" class="waitlist-input" id="wlName" placeholder="Your name" required>
        <input type="email" class="waitlist-input" id="wlEmail" placeholder="Your email" required>
        <input type="tel" class="waitlist-input" id="wlPhone" placeholder="Phone (optional)">
        <button type="submit" class="waitlist-submit" id="wlSubmit">Join the waitlist</button>
      </form>
      <div class="wl-trust">
        <span><i class="ph-fill ph-lock"></i> DPDP-compliant</span>
        <span><i class="ph-fill ph-shield-check"></i> No spam</span>
      </div>
    </div>
    <div id="waitlistSuccess" class="waitlist-success" style="display:none">
      <i class="ph-fill ph-check-circle"></i>
      <h3>You're on the list</h3>
      <p>We'll reach out when it's your turn. Welcome to arq.</p>
    </div>
  </div>
</div>

